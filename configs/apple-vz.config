# Apple Virtualization.framework guest support.
# Keep these built in because they are required before any userspace can load modules.

# Appliance policy: this kernel is intended to boot with all required drivers
# built in. Do not build a module tree for unused physical hardware.
CONFIG_MODULES=n

CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE=""
CONFIG_RD_GZIP=y
CONFIG_RD_XZ=y
CONFIG_RD_ZSTD=y
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y

# The initramfs appliance has no distro init to set a hostname. Keep uname
# useful without changing the upstream-derived kernel release string.
CONFIG_DEFAULT_HOSTNAME="droidspaces-vz"

# Apple VZ boot-platform baseline.
#
# The known-good x86_64 VZ guest enumerates ACPI tables, a PCI ECAM root
# complex, and modern VirtIO PCI devices. Keep the same ACPI/PCI/MSI contract
# on arm64 unless source-level evidence proves Apple VZ presents a different
# platform there. RELOCATABLE is required so VZLinuxBootLoader is free to
# choose a suitable physical placement for the kernel image.
CONFIG_ACPI=y
CONFIG_PCI=y
CONFIG_PCI_MSI=y
CONFIG_RELOCATABLE=y

# VirtIO core and VZ-exposed devices.
# allnoconfig disables this menuconfig parent, so requesting a
# child alone is discarded by olddefconfig.
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_PCI_LEGACY=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_VIRTIO_INPUT=y
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y

# Console path used by Apple VZ Linux samples: console=hvc0.
CONFIG_TTY=y
CONFIG_HVC_DRIVER=y
CONFIG_HVC_CONSOLE=y

# Host directory sharing through VZSingleDirectoryShare / VirtIO-FS.
CONFIG_FUSE_FS=y
CONFIG_VIRTIO_FS=y
CONFIG_DAX=y
CONFIG_FS_DAX=y

# Host/guest control channel for a future guest agent.
CONFIG_VSOCKETS=y
CONFIG_VSOCKETS_DIAG=y
CONFIG_VIRTIO_VSOCKETS=y

# Generic storage/network basics.
CONFIG_NET=y
CONFIG_INET=y
CONFIG_UNIX=y
CONFIG_PACKET=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y

# EFI capability is retained for compatible QEMU and future VZ paths.
# ACPI is declared once in the VZ boot-platform baseline above.
CONFIG_EFI=y
