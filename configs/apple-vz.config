# Apple Virtualization.framework guest support.
# Keep these built in because they are required before any userspace can load modules.

# Appliance policy: this kernel is intended to boot with all required drivers
# built in. Do not build a module tree for unused physical hardware.
CONFIG_MODULES=n

CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE=""
CONFIG_RD_GZIP=y
CONFIG_RD_XZ=y
CONFIG_RD_ZSTD=y
CONFIG_BINFMT_ELF=y

# VirtIO core and VZ-exposed devices.
CONFIG_VIRTIO=y
CONFIG_PCI=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_PCI_LEGACY=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_VIRTIO_INPUT=y
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y

# Console path used by Apple VZ Linux samples: console=hvc0.
CONFIG_TTY=y
CONFIG_HVC_DRIVER=y
CONFIG_HVC_CONSOLE=y

# Host directory sharing through VZSingleDirectoryShare / VirtIO-FS.
CONFIG_FUSE_FS=y
CONFIG_VIRTIO_FS=y
CONFIG_DAX=y
CONFIG_FS_DAX=y

# Host/guest control channel for a future guest agent.
CONFIG_VSOCKETS=y
CONFIG_VSOCKETS_DIAG=y
CONFIG_VIRTIO_VSOCKETS=y

# Generic storage/network basics.
CONFIG_NET=y
CONFIG_INET=y
CONFIG_UNIX=y
CONFIG_PACKET=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y

# ACPI/EFI are harmless and useful across VZ/QEMU boot paths.
CONFIG_EFI=y
CONFIG_ACPI=y
